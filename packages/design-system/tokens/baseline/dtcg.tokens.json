      "8": {
        "$type": "dimension",
        "$value": "1.5rem"
      },
      "10": {
        "$type": "dimension",
        "$value": "2rem"
      },
      "12": {
        "$type": "dimension",
        "$value": "3rem"
      }
    },
    "typography": {
      "fontFamily": {
        "mono": {
          "$type": "fontFamily",
          "$value": "\"SF Mono\", ui-monospace, Menlo, Monaco, monospace"
        },
        "sans": {
          "$type": "fontFamily",
          "$value": "\"SF Pro Display\", \"SF Pro Text\", -apple-system, BlinkMacSystemFont, \"Segoe UI\", sans-serif"
        }
      },
      "fontSize": {
        "2xl": {
          "$type": "dimension",
          "$value": "2rem"
        },
        "lg": {
          "$type": "dimension",
          "$value": "1.125rem"
        },
        "md": {
          "$type": "dimension",
          "$value": "1rem"
        },
        "sm": {
          "$type": "dimension",
          "$value": "0.875rem"
        },
        "xl": {
          "$type": "dimension",
          "$value": "1.5rem"
        },
        "xs": {
          "$type": "dimension",
          "$value": "0.75rem"
        }
      },
      "fontWeight": {
        "bold": {
          "$type": "fontWeight",
          "$value": 700
        },
        "medium": {
          "$type": "fontWeight",
          "$value": 500
        },
        "regular": {
          "$type": "fontWeight",
          "$value": 400
        },
        "semibold": {
          "$type": "fontWeight",
          "$value": 600
        }
      },
      "lineHeight": {
        "base": {
          "$type": "number",
          "$value": 1.45
        },
        "relaxed": {
          "$type": "number",
          "$value": 1.65
        },
        "tight": {
          "$type": "number",
          "$value": 1.2
        }
      }
    }
  },
  "runtime": {
    "chrono": {
      "morning": {
        "navicue": {
          "atmosphere": {
            "highlight": {
              "$type": "color",
              "$value": "{primitives.colors.amber.400}"
            },
            "temperatureOffset": {
              "$type": "dimension",
              "$value": "0.25rem"
            }
          },
          "motion": {
            "entryDuration": {
              "$type": "duration",
              "$value": "420ms"
            }
          }
        }
      },
      "night": {
        "navicue": {
          "atmosphere": {
            "highlight": {
              "$type": "color",
              "$value": "{primitives.colors.indigo.300}"
            },
            "temperatureOffset": {
              "$type": "dimension",
              "$value": "-0.25rem"
            }
          },
          "motion": {
            "entryDuration": {
              "$type": "duration",
              "$value": "620ms"
            }
          }
        }
      }
    },
    "heat": {
      "green": {
        "navicue": {
          "copyDensity": {
            "maxLines": {
              "$type": "number",
              "$value": 3
            }
          },
          "interaction": {
            "cognitiveLoad": {
              "$type": "string",
              "$value": "low"
            }
          }
        }
      },
      "red": {
        "navicue": {
          "copyDensity": {
            "maxLines": {
              "$type": "number",
              "$value": 1
            }
          },
          "interaction": {
            "cognitiveLoad": {
              "$type": "string",
              "$value": "minimal"
            }
          }
        }
      }
    }
  },
  "semantic": {
