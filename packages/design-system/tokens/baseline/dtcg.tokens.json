          "$value": "#0A8F8B"
        }
      }
    },
    "motion": {
      "duration": {
        "base": {
          "$type": "duration",
          "$value": "220ms"
        },
        "fast": {
          "$type": "duration",
          "$value": "140ms"
        },
        "instant": {
          "$type": "duration",
          "$value": "80ms"
        },
        "ritual": {
          "$type": "duration",
          "$value": "600ms"
        },
        "slow": {
          "$type": "duration",
          "$value": "380ms"
        }
      },
      "easing": {
        "enter": {
          "$type": "cubicBezier",
          "$value": [
            0.12,
            0,
            0.08,
            1
          ]
        },
        "exit": {
          "$type": "cubicBezier",
          "$value": [
            0.4,
            0,
            1,
            1
          ]
        },
        "standard": {
          "$type": "cubicBezier",
          "$value": [
            0.22,
            0,
            0,
            1
          ]
        }
      }
    },
    "spacing": {
      "0": {
        "$type": "dimension",
        "$value": "0rem"
      },
      "1": {
        "$type": "dimension",
        "$value": "0.125rem"
      },
      "2": {
        "$type": "dimension",
        "$value": "0.25rem"
      },
      "3": {
        "$type": "dimension",
        "$value": "0.5rem"
      },
      "4": {
        "$type": "dimension",
        "$value": "0.75rem"
