    "sans": "\"SF Pro Display\", \"SF Pro Text\", -apple-system, BlinkMacSystemFont, \"Segoe UI\", sans-serif",
    "mono": "\"SF Mono\", ui-monospace, Menlo, Monaco, monospace"
  },
  "fontSize": {
    "xs": "0.75rem",
    "sm": "0.875rem",
